<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@drawable/bg_notification_activity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <!-- Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔔 Notification Demo"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Learn and test Android Local Notifications"
                        android:textSize="14sp"
                        android:alpha="0.7"
                        android:textAlignment="center" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Main Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/localNotificationButton"
                android:layout_width="250dp"
                android:layout_height="56dp"
                android:text="Local Notification"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_dialog_info"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/FirebaseNotification"
                android:layout_width="250dp"
                android:layout_height="56dp"
                android:text="Firebase Notification"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_dialog_info"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/camerAPI"
                android:layout_width="250dp"
                android:layout_height="56dp"
                android:text="Camera API"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_dialog_info"
                app:iconGravity="textStart" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/mediaActivity"
                android:layout_width="250dp"
                android:layout_height="56dp"
                android:text="Media Acitvity"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_dialog_info"
                app:iconGravity="textStart" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/mapsActivity"
                android:layout_width="250dp"
                android:layout_height="56dp"
                android:text="Maps Acitvity"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/ic_dialog_info"
                app:iconGravity="textStart" />


        </LinearLayout>

    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>