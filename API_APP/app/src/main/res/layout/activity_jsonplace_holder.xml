<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".JSONPlaceHolder">
    <LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F5F7FB">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JSON Placeholder API"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp"/>

        <!-- BUTTON ROW (POST, PUT, PATCH, DELETE) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="4"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/sendPostButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="POST"
                android:textAllCaps="false"/>

            <Button
                android:id="@+id/sendPutButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PUT"
                android:textAllCaps="false"
                android:layout_marginStart="5dp"/>

            <Button
                android:id="@+id/sendPatchButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="PATCH"
                android:textAllCaps="false"
                android:layout_marginStart="5dp"/>

            <Button
                android:id="@+id/sendDeleteButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="DELETE"
                android:textAllCaps="false"
                android:layout_marginStart="5dp"/>
        </LinearLayout>

        <!-- OUTPUT AREA -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/jsonPlaceholderTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Posts will appear here..."
                android:textSize="16sp"
                android:textColor="#333333"
                android:padding="10dp"/>

        </ScrollView>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>